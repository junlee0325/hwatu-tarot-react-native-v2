{
  "expo": {
    "name": "hwatu-tarot-v2",
    "slug": "hwatu-tarot-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon2.png",
    "scheme": "hwatutarotv2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/icon2.png",
      "adaptiveIcon": {
  "foregroundImage": "./assets/icon1.png",
  "backgroundColor": "#1b3320"
},
      "predictiveBackGestureEnabled": false,
      "package": "com.junlee0325.hwatutarotv2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon1.png",
          "backgroundColor": "#1b3320",
          "dark": {
            "backgroundColor": "#1b3320"
          }
        }
      ],
      "expo-audio",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}